{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/projects/wedding-lens/.claude/hooks/bash-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/projects/wedding-lens/.claude/hooks/lint-python.sh",
            "timeout": 30,
            "async": true
          },
          {
            "type": "command",
            "command": "/projects/wedding-lens/.claude/hooks/lint-ts.sh",
            "timeout": 60,
            "async": true
          },
          {
            "type": "command",
            "command": "/projects/wedding-lens/.claude/hooks/arch-drift-guard.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
